# ---- Unity generated (반드시 제외: Library는 2GB+ 캐시) ----
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]serSettings/
[Mm]emoryCaptures/

# Asset meta 파일은 대응 에셋이 무시될 때만 무시
!/[Aa]ssets/**/*.meta

# 자동생성 VS/솔루션/프로젝트 파일
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity 메타/크래시
*.pidb.meta
*.pdb.meta
*.mdb.meta
sysinfo.txt

# 빌드 산출물
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics
crashlytics-build.properties

# Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# OS
.DS_Store
Thumbs.db

# IDE
.vs/
.idea/
.vscode/

# OMC 오케스트레이션 상태
.omc/

# WebGL 배포 빌드는 커밋해야 함 (GitHub Pages 소스). 위 [Bb]uild/ 규칙이
# docs/Build/까지 무시하므로 여기서 예외 처리.
!/docs/Build/
!/docs/Build/**
